PORT=4000
TARGET_PROFIT_MARGIN=0.15

# Frontend / custom-domain cutover
FRONTEND_BASE_URL=https://custom-ecommerce-seven.vercel.app
API_BASE_URL=https://custom-ecommerce-qp30.onrender.com
CORS_ALLOWED_ORIGINS=https://custom-ecommerce-seven.vercel.app,http://localhost:5173

# Printify
ENABLE_PRINTIFY_SYNC=false
PRINTIFY_API_TOKEN=your_printify_token
PRINTIFY_SHOP_ID=27495153
PRINTIFY_WEBHOOK_URL=https://custom-ecommerce-qp30.onrender.com/api/webhooks/printify

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_OWNER_CHAT_ID=your_telegram_chat_id

# Stripe live
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPlus
PAYPLUS_API_KEY=your_payplus_api_key

# Resend (transactional email)
RESEND_API_KEY=
BRAND_LOGO_URL=

# Admin (shared secret for /api/admin/set-coupon — must match DRIP_ADMIN_SECRET in MENI_CORE)
DRIP_ADMIN_SECRET=