VITE_API_BASE_URL=https://custom-ecommerce-qp30.onrender.com

# PayPal (frontend client id — public, safe to expose)
VITE_PAYPAL_CLIENT_ID=

# Marketing pixels (leave blank to skip injection — placeholder values are also ignored)
# GA4 ID format:   G-XXXXXXXXXX
# Meta Pixel ID:   15-16 digit numeric string from Events Manager
# TikTok Pixel ID: alphanumeric string from TikTok Events Manager
VITE_GA4_ID=
VITE_META_PIXEL_ID=
VITE_TIKTOK_PIXEL_ID=

# Optional client-side checkout knobs
VITE_ABANDONED_CART_DELAY_MS=
