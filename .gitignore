# Environment files
.env
.env.local
.env.production
*.env
backend/.env
frontend/.env

# Local DB backups and operational reports — contain customer data / noise
backend/backups/
backend/reports/

# SQLite WAL/SHM runtime sidecar files — never commit
backend/*.db-wal
backend/*.db-shm
*.db-wal
*.db-shm

# Placeholder mockup assets used only for local pipeline smoke tests —
# production uses the Cloudinary URLs in MOCKUP_TEMPLATE_* env vars.
backend/mockup-assets-dummy/
